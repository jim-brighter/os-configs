alias l="ls -lh"
alias la="ls -ahl"
alias l1="ls -1"
alias ..="cd .."

alias update="sudo apt update && sudo apt full-upgrade -y && sudo apt autoremove"

export JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64

function clone() {
  prefix=$(echo $1 | cut -c1-3)
  if [[ "$prefix" == "git" ]]; then
    owner=$(echo $1 | cut -d':' -f 2 | cut -d'/' -f 1)
  else
    owner=$(echo $1 | cut -d'/' -f 4)
  fi

  mkdir -p $owner && cd $owner

  git clone $1
}
